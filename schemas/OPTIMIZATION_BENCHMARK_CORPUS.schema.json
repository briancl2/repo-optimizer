{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Optimization Benchmark Corpus",
  "type": "object",
  "required": ["schema_version", "artifact", "corpus_id", "workloads"],
  "properties": {
    "schema_version": { "type": "string" },
    "artifact": { "const": "OPTIMIZATION_BENCHMARK_CORPUS" },
    "corpus_id": { "type": "string", "minLength": 1 },
    "target_label": { "type": "string" },
    "generated_at": { "type": "string" },
    "thresholds": { "type": "object" },
    "minimum_corpus": { "type": "object" },
    "workloads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["workload_id", "source_repo", "bucket", "tactic_id", "baseline", "candidate"],
        "properties": {
          "workload_id": { "type": "string", "minLength": 1 },
          "source_repo": { "type": "string", "minLength": 1 },
          "bucket": { "type": "string", "minLength": 1 },
          "tactic_id": { "type": "string", "minLength": 1 },
          "workload_role": { "type": "string" },
          "admission_status": { "type": "string" },
          "allowed_modes": {
            "type": "array",
            "items": { "enum": ["deterministic", "retained-replay", "live-paired"] }
          },
          "claim_types": {
            "type": "array",
            "items": { "enum": ["token", "output_noise", "wall_time", "cache"] }
          },
          "target_repo_mutated": { "type": "boolean" },
          "counts_toward_promotion": { "type": "boolean" },
          "provider": { "type": "string" },
          "harness": { "type": "string" },
          "model": { "type": "string" },
          "model_version": { "type": "string" },
          "model_family": { "type": "string" },
          "observed_at": { "type": "string" },
          "prompt_hash": { "type": "string" },
          "fixture_hash": { "type": "string" },
          "observed_mean_delta": { "type": "number" },
          "paired_delta_samples": {
            "type": "array",
            "items": { "type": "number" }
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "baseline": {
            "type": "object",
            "properties": {
              "input_hash": { "type": "string" },
              "input_tokens": { "type": "number" },
              "input_tokens_source": { "enum": ["direct", "proxy"] },
              "irrelevant_output_bytes": { "type": "number" },
              "wall_time_ms": { "type": "number" },
              "cache_hit_rate_pct": { "type": "number" },
              "stable_prefix_tokens": { "type": "number" },
              "correctness_pass": { "type": "boolean" },
              "closeout_truth_pass": { "type": "boolean" },
              "run_count": { "type": "number" }
            },
            "additionalProperties": true
          },
          "candidate": {
            "type": "object",
            "properties": {
              "input_hash": { "type": "string" },
              "input_tokens": { "type": "number" },
              "input_tokens_source": { "enum": ["direct", "proxy"] },
              "irrelevant_output_bytes": { "type": "number" },
              "wall_time_ms": { "type": "number" },
              "cache_hit_rate_pct": { "type": "number" },
              "stable_prefix_tokens": { "type": "number" },
              "correctness_pass": { "type": "boolean" },
              "closeout_truth_pass": { "type": "boolean" },
              "run_count": { "type": "number" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
