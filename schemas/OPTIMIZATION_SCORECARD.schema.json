{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Optimization Result Scorecard",
  "description": "Machine-readable optimization result with finding counts, patch stats, and expected delta.",
  "type": "object",
  "required": [
    "findings_total",
    "findings_approved",
    "findings_rejected",
    "patches_generated",
    "patches_valid",
    "expected_delta"
  ],
  "properties": {
    "findings_total": {
      "type": "integer",
      "minimum": 0,
      "description": "Total findings discovered across all domain subagents"
    },
    "findings_approved": {
      "type": "integer",
      "minimum": 0,
      "description": "Findings approved by adversarial critic"
    },
    "findings_rejected": {
      "type": "integer",
      "minimum": 0,
      "description": "Findings rejected by adversarial critic (must be ≥1)"
    },
    "findings_downgraded": {
      "type": "integer",
      "minimum": 0,
      "description": "Findings downgraded by adversarial critic"
    },
    "patches_generated": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5,
      "description": "Number of patches generated (max 5 per run)"
    },
    "patches_valid": {
      "type": "integer",
      "minimum": 0,
      "description": "Patches that pass git apply --check"
    },
    "expected_delta": {
      "type": "integer",
      "description": "Expected composite score improvement"
    },
    "coverage_verdict": {
      "type": "string",
      "enum": ["complete", "partial", "blocked", "pass_with_coverage_gap"],
      "description": "Additive discovery-coverage verdict; does not replace ROI, receipt, or score trend fields"
    },
    "recommendation_strength": {
      "type": "string",
      "enum": ["strong", "limited", "diagnostic", "none"],
      "description": "Maximum supported recommendation strength after applying discovery coverage constraints"
    },
    "discovery_coverage": {
      "type": "object",
      "description": "Domain coverage metadata for the four optimizer discovery domains",
      "properties": {
        "coverage_verdict": {
          "type": "string",
          "enum": ["complete", "partial", "blocked", "pass_with_coverage_gap"]
        },
        "schema_version": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "coverage_reason": { "type": "string" },
        "recommendation_strength": {
          "type": "string",
          "enum": ["strong", "limited", "diagnostic", "none"]
        },
        "expected_domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "completed_domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "completed_count": { "type": "integer", "minimum": 0 },
        "missing_count": { "type": "integer", "minimum": 0 },
        "expected_count": { "type": "integer", "minimum": 0 },
        "coverage_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "domain_finding_rows": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "discovery_attempted": { "type": "boolean" },
        "preflight_only": { "type": "boolean" },
        "critic_status": { "type": "string" },
        "synthesis_status": { "type": "string" },
        "patch_status": { "type": "string" },
        "bounded_non_claims": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "finding_count_agreement": {
      "type": "object",
      "description": "Agreement check between the deterministic human plan coverage section and JSON finding counts",
      "properties": {
        "source": { "type": "string" },
        "plan_declared_counts": {
          "type": ["object", "null"],
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "approved": { "type": "integer", "minimum": 0 },
            "rejected": { "type": "integer", "minimum": 0 },
            "downgraded": { "type": "integer", "minimum": 0 }
          }
        },
        "scorecard_counts": {
          "type": "object",
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "approved": { "type": "integer", "minimum": 0 },
            "rejected": { "type": "integer", "minimum": 0 },
            "downgraded": { "type": "integer", "minimum": 0 }
          }
        },
        "matches_scorecard": { "type": "boolean" }
      }
    },
    "bounded_non_claims": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-claims that bound partial coverage outputs"
    },
    "cleanup_contract": {
      "type": "object",
      "description": "Additive P5 cleanup-safety contract metadata; does not change score semantics.",
      "properties": {
        "schema_version": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "findings_with_cleanup_class": { "type": "integer", "minimum": 0 },
        "destructive_findings_total": { "type": "integer", "minimum": 0 },
        "destructive_findings_blocked": { "type": "integer", "minimum": 0 },
        "destructive_findings_authorized": { "type": "integer", "minimum": 0 },
        "missing_owner_boundary_count": { "type": "integer", "minimum": 0 },
        "missing_keep_set_count": { "type": "integer", "minimum": 0 },
        "authorization_required_missing_count": { "type": "integer", "minimum": 0 },
        "unclassified_requires_amendment_count": { "type": "integer", "minimum": 0 },
        "patch_generation_blocked": { "type": "boolean" },
        "bounded_non_claims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "findings": {
          "type": "array",
          "items": { "$ref": "CLEANUP_FINDING_METADATA.schema.json" }
        }
      }
    },
    "categories": {
      "type": "object",
      "description": "Finding counts per optimization category",
      "properties": {
        "decompose": { "type": "integer", "minimum": 0 },
        "consolidate": { "type": "integer", "minimum": 0 },
        "extract": { "type": "integer", "minimum": 0 },
        "standardize": { "type": "integer", "minimum": 0 }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "optimizer_version": { "type": "string" },
        "scorecard_input": { "type": "string" },
        "target": { "type": "string" }
      }
    }
  }
}
